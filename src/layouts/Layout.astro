---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dclick IA | Le déclic IA pour votre métier',
  description = 'Le déclic IA pour votre métier. Audit flash gratuit.',
} = Astro.props;
---

<!doctype html>
<html lang="fr" class="scroll-smooth bg-[#0A0A0A]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://dclick-ia.fr" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Canonical -->
    <link rel="canonical" href="https://dclick-ia.fr" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Lucide icons -->
    <script is:inline src="https://unpkg.com/lucide@latest"></script>

    <title>{title}</title>
  </head>
  <body class="font-sans antialiased text-white bg-[#0A0A0A] selection:bg-[#2E7BD4]/30 min-h-screen flex flex-col relative overflow-x-hidden">

    <!-- Background grid -->
    <div class="fixed inset-0 z-[-2] bg-[linear-gradient(to_right,#4f4f4f15_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f15_1px,transparent_1px)] bg-[size:32px_32px] pointer-events-none"></div>

    <!-- Top blue glow -->
    <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-[#2E7BD4]/20 rounded-full blur-[120px] pointer-events-none z-[-1]"></div>

    <slot />

    <script is:inline>
      lucide.createIcons({ strokeWidth: 1.5 });
    </script>
  </body>
</html>
