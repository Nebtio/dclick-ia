---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Atelier IA pratique pour entreprises (360€ HT) | Dclick IA"
  description="Rendez vos équipes autonomes sur les outils IA. Atelier d'une demi-journée, sur site ou à distance. Prompting, création de contenu, charte IA interne."
>

  <!-- ——— PAGE HERO ——— -->
  <div class="page-hero">
    <div class="container">
      <span class="page-tag">Étape 01 — Maîtriser</span>
      <h1>Ateliers pratiques IA — rendez vos équipes autonomes</h1>
      <p class="page-lead">
        Pas de jargon, pas de théorie inutile. Vos collaborateurs repartent avec des outils qu'ils utilisent dès le lendemain.
      </p>
    </div>
  </div>

  <!-- ——— OFFRE ATELIERS ——— -->
  <section>
    <div class="container">
      <div class="parcours-grid" style="max-width: 700px;">

        <div class="parcours-card step-maitriser">
          <span class="step-number">01</span>
          <span class="step-badge">Maîtriser</span>
          <h3>Ateliers pratiques</h3>
          <p class="step-desc">Rendre vos équipes autonomes sur les outils IA du quotidien et de création de contenu.</p>
          <ul>
            <li>Prise en main des assistants IA du quotidien</li>
            <li>Création de contenu assistée : texte, image, vidéo</li>
            <li>Bonnes pratiques et méthode de prompting</li>
            <li>Mini-charte IA interne pour encadrer les usages</li>
          </ul>
          <p class="step-price">À partir de 400€ HT</p>
          <p class="step-format">½ journée ou 1 journée | Tous collaborateurs | Sur site ou à distance</p>
          <p class="step-result">Adoption sereine · Usage cadré · Autonomie rapide</p>
          <span class="rgpd-badge">✓ Conforme RGPD</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ——— POUR QUI ——— -->
  <section style="border-top: 1px solid var(--clr-border);">
    <div class="container">
      <h2 class="section-title">Pour <span class="text-accent">qui ?</span></h2>
      <p class="section-subtitle">L'atelier s'adapte à votre secteur et à votre niveau de départ.</p>
      <div class="pain-grid">
        <div class="pain-card">
          <p class="pain-quote">Artisans & TPE</p>
          <p class="pain-answer">→ Gagner du temps sur devis, mails, réseaux sociaux</p>
        </div>
        <div class="pain-card">
          <p class="pain-quote">Équipes PME</p>
          <p class="pain-answer">→ Automatiser la création de contenu et les rapports</p>
        </div>
        <div class="pain-card">
          <p class="pain-quote">Managers & dirigeants</p>
          <p class="pain-answer">→ Comprendre l'IA pour guider leurs équipes</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— CTA ——— -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box">
        <h2 class="section-title">Prêt à former <span class="text-accent">votre équipe</span> ?</h2>
        <p>Commençons par un diagnostic flash gratuit de 30 min pour valider que l'atelier est adapté à votre situation.</p>
        <a href="/diagnostic-flash" class="btn-primary">Réserver mon diagnostic gratuit →</a>
        <div class="cta-meta">
          <span>Sans engagement</span>
          <span>Basé à Gien, Centre-Val de Loire</span>
        </div>
      </div>
    </div>
  </section>

</SiteLayout>
