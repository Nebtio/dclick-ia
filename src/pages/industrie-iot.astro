---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="IoT & données terrain pour PME industrielles | Dclick IA"
  description="Captez et exploitez vos données terrain grâce à l'IoT et l'IA. Diagnostic data, capteurs connectés, tableaux de bord. Consultant basé en Centre-Val de Loire."
>

  <!-- ——— PAGE HERO ——— -->
  <div class="page-hero">
    <div class="container">
      <span class="page-tag" style="color: var(--clr-iot);">Pour aller plus loin — Industrie & Production</span>
      <h1>IoT &amp; données terrain</h1>
      <p class="page-lead">
        Vous avez des machines. Elles produisent des données.<br />
        La question : est-ce qu'elles servent à quelque chose ?
      </p>
    </div>
  </div>

  <!-- ——— OFFRE IOT ——— -->
  <section>
    <div class="container">
      <div class="parcours-grid" style="max-width: 700px;">

        <div class="parcours-card step-piloter">
          <span class="step-number">03</span>
          <span class="step-badge">Pour aller plus loin</span>
          <h3>IoT &amp; données terrain</h3>
          <p class="step-desc">Captez, comprenez et anticipez grâce à vos données terrain.</p>
          <ul>
            <li>Diagnostic data et étude de faisabilité</li>
            <li>Capteurs connectés sur site</li>
            <li>Plan d'exploitation et de visualisation des données</li>
          </ul>
          <p class="step-result">Décisions pilotées par la donnée terrain</p>
          <span class="rgpd-badge">✓ Conforme RGPD</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ——— EXEMPLES CONCRETS ——— -->
  <section style="border-top: 1px solid var(--clr-border);">
    <div class="container">
      <h2 class="section-title">Quelques exemples <span class="text-accent">concrets</span></h2>
      <div class="pain-grid">
        <div class="pain-card">
          <p class="pain-answer">→ Une alerte quand une machine vibre anormalement</p>
        </div>
        <div class="pain-card">
          <p class="pain-answer">→ Un suivi de conso énergie poste par poste</p>
        </div>
        <div class="pain-card">
          <p class="pain-answer">→ Un historique de production sans saisie manuelle</p>
        </div>
        <div class="pain-card">
          <p class="pain-answer">→ Un tableau de bord lisible en réunion du lundi</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— PROFIL ——— -->
  <section style="border-top: 1px solid var(--clr-border);">
    <div class="container">
      <h2 class="section-title">Ce qu'on fait <span class="text-accent">ensemble</span></h2>
      <div class="pain-grid">
        <div class="pain-card">
          <p class="pain-answer">→ On identifie les données déjà disponibles</p>
        </div>
        <div class="pain-card">
          <p class="pain-answer">→ On voit ce qu'on peut en tirer</p>
        </div>
        <div class="pain-card">
          <p class="pain-answer">→ On décide si ça vaut le coup d'aller plus loin</p>
        </div>
      </div>
      <p class="signature" style="margin-top: 2.5rem;">
        <strong>Ancien automaticien industriel.</strong><br />
        Je connais le terrain avant de parler d'IA.
      </p>
    </div>
  </section>

  <!-- ——— CTA ——— -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box">
        <h2 class="section-title">Évaluons votre <span class="text-accent">potentiel data</span></h2>
        <p>Diagnostic flash gratuit de 30 min — on regarde ensemble si vos données terrain peuvent être exploitées.</p>
        <a href="/diagnostic-flash" class="btn-primary">Réserver mon diagnostic gratuit →</a>
        <div class="cta-meta">
          <span>Sans engagement</span>
          <span>Basé à Gien, Centre-Val de Loire</span>
        </div>
      </div>
    </div>
  </section>

</SiteLayout>
