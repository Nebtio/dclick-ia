---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Automatisation IA pour PME & services | Dclick IA, Loiret"
  description="Automatisez devis, relances et saisies administratives avec l'IA. Résultats en moins de 30 jours. Consultant spécialisé TPE/PME à Gien."
>

  <!-- ——— PAGE HERO ——— -->
  <div class="page-hero">
    <div class="container">
      <span class="page-tag">PME & Services</span>
      <h1>Automatisation IA pour PME — libérez-vous des tâches répétitives</h1>
      <p class="page-lead">
        Devis, relances, saisies, rapports hebdo — ces tâches prennent du temps mais n'apportent aucune valeur. L'IA les prend en charge. Résultats en moins de 30 jours.
      </p>
    </div>
  </div>

  <!-- ——— PROFIL CIBLE ——— -->
  <section>
    <div class="container">
      <h2 class="section-title">Fait pour <span class="text-accent">votre structure</span></h2>
      <p class="section-subtitle">L'automatisation IA s'applique dès qu'il y a des tâches répétitives dans votre quotidien.</p>
      <div class="profils-grid">
        <div class="profil-card">
          <h3>PME & Services</h3>
          <p class="profil-pain">"Mon équipe résiste, je ne sais pas quoi automatiser"</p>
          <p class="profil-reco">
            → Diagnostic de rentabilité (1 000€ HT)<br />
            → puis Ateliers pratiques
          </p>
        </div>
        <div class="profil-card">
          <h3>Agences & cabinets</h3>
          <p class="profil-pain">"On passe des heures sur du traitement de données"</p>
          <p class="profil-reco">
            → Tri automatique, rapports auto<br />
            → Gain immédiat sur les tâches à faible valeur
          </p>
        </div>
        <div class="profil-card">
          <h3>Commerce & distribution</h3>
          <p class="profil-pain">"Les relances clients, les devis, ça prend trop de temps"</p>
          <p class="profil-reco">
            → Automatisation des relances et devis<br />
            → Moins d'administratif, plus de terrain
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— CAS D'USAGE ——— -->
  <section style="border-top: 1px solid var(--clr-border);">
    <div class="container">
      <h2 class="section-title">3 exemples <span class="text-accent">concrets</span></h2>
      <p class="section-subtitle">Des cas réels, des gains mesurables.</p>

      <div class="cas-grid">
        <div class="cas-card">
          <h4>Artisan / TPE — Devis à la voix</h4>
          <div class="pas-block">
            <span class="pas-label">Problème</span>
            <p>45 minutes par devis, chaque jour. Du temps perdu sur de l'administratif.</p>
          </div>
          <div class="pas-block action">
            <span class="pas-label">Action</span>
            <p>L'artisan dicte ses notes au téléphone, en rentrant du chantier.</p>
          </div>
          <div class="pas-block solution">
            <span class="pas-label">Résultat</span>
            <p>Le devis est rédigé, mis en forme et prêt à envoyer en 3 minutes.</p>
          </div>
        </div>
        <div class="cas-card">
          <h4>Agence d'intérim — Tri de candidatures</h4>
          <div class="pas-block">
            <span class="pas-label">Problème</span>
            <p>2 heures pour trier 50 CV à chaque ouverture de poste.</p>
          </div>
          <div class="pas-block action">
            <span class="pas-label">Action</span>
            <p>Les CV sont analysés automatiquement selon les critères du poste.</p>
          </div>
          <div class="pas-block solution">
            <span class="pas-label">Résultat</span>
            <p>Les profils pertinents remontent en tête, classés et commentés, en quelques secondes.</p>
          </div>
        </div>
        <div class="cas-card">
          <h4>Direction PME — Réunion préparée</h4>
          <div class="pas-block">
            <span class="pas-label">Problème</span>
            <p>Réunion de direction sans chiffres à jour — décisions prises à l'aveugle.</p>
          </div>
          <div class="pas-block action">
            <span class="pas-label">Action</span>
            <p>Un rapport est généré automatiquement chaque lundi matin.</p>
          </div>
          <div class="pas-block solution">
            <span class="pas-label">Résultat</span>
            <p>Chiffres clés, tendances et alertes — prêts avant la réunion, sans saisie manuelle.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— CE QU'ON AUTOMATISE ——— -->
  <section style="border-top: 1px solid var(--clr-border);">
    <div class="container">
      <h2 class="section-title">Ce qu'on peut <span class="text-accent">automatiser</span></h2>
      <p class="section-subtitle">Voici les tâches les plus fréquemment ciblées dans les PME & services.</p>
      <div class="pain-grid">
        <div class="pain-card">
          <p class="pain-quote">Saisies administratives répétitives</p>
          <p class="pain-answer">→ Extraction et structuration automatique des données</p>
        </div>
        <div class="pain-card">
          <p class="pain-quote">Relances clients & fournisseurs</p>
          <p class="pain-answer">→ Séquences automatiques basées sur des déclencheurs</p>
        </div>
        <div class="pain-card">
          <p class="pain-quote">Rapports hebdomadaires</p>
          <p class="pain-answer">→ Générés automatiquement à partir de vos données</p>
        </div>
        <div class="pain-card">
          <p class="pain-quote">Tri et classement de documents</p>
          <p class="pain-answer">→ Analyse et organisation automatique par l'IA</p>
        </div>
        <div class="pain-card">
          <p class="pain-quote">Réponses aux demandes courantes</p>
          <p class="pain-answer">→ Modèles intelligents adaptés à votre contexte</p>
        </div>
        <div class="pain-card">
          <p class="pain-quote">Suivi de production ou de planning</p>
          <p class="pain-answer">→ Alertes et tableaux de bord en temps réel</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— CTA ——— -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box">
        <h2 class="section-title">Identifiez vos <span class="text-accent">3 premiers gains</span></h2>
        <p>Diagnostic flash gratuit de 30 min — on cible ensemble ce qui peut être automatisé dans votre quotidien.</p>
        <a href="/diagnostic-flash" class="btn-primary">Réserver mon diagnostic gratuit →</a>
        <div class="cta-meta">
          <span>Sans engagement</span>
          <span>Résultats en moins de 30 jours</span>
        </div>
      </div>
    </div>
  </section>

</SiteLayout>
