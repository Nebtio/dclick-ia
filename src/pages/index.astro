---
// Dclick IA – Landing Page — Dark SaaS Premium Style
---

<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Consultant IA pour TPE & PME — Automatisation & IA | Dclick IA, Gien</title>
  <meta name="description" content="Automatisez vos devis, relances et saisies avec l'IA. Résultats en moins de 30 jours, sans formation lourde. Diagnostic gratuit (30 min). Consultant indépendant basé à Gien, Centre-Val de Loire." />
  <link rel="icon" type="image/png" href="/LogoDclickV2.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg:        #080808;
      --surface:   #101010;
      --surface-2: #161616;
      --surface-3: #1c1c1c;
      --border:    rgba(255,255,255,0.06);
      --border-md: rgba(255,255,255,0.1);
      --accent:    #2B6CB0;
      --accent-dim: rgba(43,108,176,0.18);
      --accent-glow: rgba(43,108,176,0.12);
      --success:   #34D399;
      --purple:    #A78BFA;
      --text:      #E8E6E3;
      --muted:     #6B7280;
      --muted-2:   #9CA3AF;
      --font:      'Sora', sans-serif;
      --mono:      'Space Mono', monospace;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── Grain overlay ─── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 100;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      opacity: 0.4;
    }

    /* ─── Utility ─── */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
    .accent    { color: var(--accent); }
    .muted     { color: var(--muted-2); }
    .mono      { font-family: var(--mono); }

    /* ─── Animations ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulse-dot {
      0%,100% { opacity: 1; }
      50%      { opacity: 0.3; }
    }
    .au { opacity: 0; animation: fadeUp 0.8s cubic-bezier(0.16,1,0.3,1) forwards; }
    .d1 { animation-delay: 0.05s; }
    .d2 { animation-delay: 0.15s; }
    .d3 { animation-delay: 0.25s; }
    .d4 { animation-delay: 0.38s; }
    .d5 { animation-delay: 0.50s; }

    /* ─────────────────────────────────────────
       NAV — floating pill
    ───────────────────────────────────────── */
    nav {
      position: fixed;
      top: 1.25rem;
      left: 50%;
      transform: translateX(-50%);
      width: calc(100% - 2rem);
      max-width: 960px;
      z-index: 200;
      border-radius: 100px;
      background: rgba(10,10,10,0.82);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border-md);
      padding: 0.6rem 1.25rem;
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .nav-brand {
      font-family: var(--font);
      font-size: 1.15rem;
      font-weight: 800;
      color: var(--text);
      text-decoration: none;
      white-space: nowrap;
      letter-spacing: -0.05em;
    }
    .nav-brand .ia { color: #2B6CB0; }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 1.75rem;
    }
    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      transition: color 0.2s;
      white-space: nowrap;
    }
    .nav-links a:hover { color: var(--text); }
    .nav-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--text);
      color: var(--bg);
      padding: 0.5rem 1.1rem;
      border-radius: 100px;
      font-size: 0.82rem;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.25s cubic-bezier(0.16,1,0.3,1);
      white-space: nowrap;
    }
    .nav-cta:hover { background: #fff; transform: scale(1.03); }
    .nav-toggle {
      display: none;
      background: none;
      border: 1px solid var(--border-md);
      color: var(--text);
      width: 36px; height: 36px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 1rem;
      align-items: center;
      justify-content: center;
    }

    /* ─────────────────────────────────────────
       HERO
    ───────────────────────────────────────── */
    .hero {
      min-height: 100dvh;
      display: flex;
      align-items: center;
      padding: 7rem 0 4rem;
      position: relative;
      overflow: hidden;
      background:
        linear-gradient(to right, rgba(8,8,8,0.92) 0%, rgba(8,8,8,0.62) 55%, rgba(8,8,8,0.18) 100%),
        url('/DclikAtelier.png') center right / cover no-repeat;
    }

    /* diagonal decorative lines */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image:
        repeating-linear-gradient(
          -52deg,
          transparent 0px,
          transparent 120px,
          rgba(255,255,255,0.015) 120px,
          rgba(255,255,255,0.015) 121px
        );
    }

    /* radial glow left */
    .hero::after {
      content: '';
      position: absolute;
      bottom: -100px;
      left: -100px;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(59,130,246,0.05) 0%, transparent 65%);
      pointer-events: none;
    }

    .hero-content { position: relative; z-index: 1; max-width: 740px; }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--accent);
      background: var(--accent-dim);
      border: 1px solid rgba(59,130,246,0.25);
      border-radius: 100px;
      padding: 0.3rem 0.85rem;
      margin-bottom: 2rem;
      letter-spacing: 0.02em;
    }
    .hero-badge-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: pulse-dot 2s ease-in-out infinite;
    }

    .hero h1 {
      font-size: clamp(2.4rem, 5.5vw, 4rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
      color: #F0EFEC;
    }
    .hero h1 em {
      font-style: normal;
      color: var(--muted-2);
      font-weight: 300;
    }

    .hero-sub {
      font-size: 1rem;
      color: var(--muted-2);
      line-height: 1.75;
      max-width: 520px;
      margin-bottom: 2.5rem;
    }

    .hero-actions {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.6rem;
      margin-bottom: 3.5rem;
    }
    .hero-guarantee {
      font-size: 0.78rem;
      color: var(--muted);
      margin: 0;
      letter-spacing: 0.01em;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--text);
      color: var(--bg);
      padding: 0.75rem 1.5rem;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.25s cubic-bezier(0.16,1,0.3,1);
    }
    .btn-primary:hover { background: #fff; transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,0.4); }
    .btn-primary:active { transform: scale(0.98); }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: transparent;
      color: var(--muted-2);
      padding: 0.75rem 1.5rem;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      border: 1px solid var(--border-md);
      transition: all 0.25s cubic-bezier(0.16,1,0.3,1);
    }
    .btn-ghost:hover { color: var(--text); border-color: rgba(255,255,255,0.2); transform: translateY(-2px); }

    /* hero metrics strip */
    .hero-metrics {
      display: flex;
      gap: 0;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      width: fit-content;
      max-width: 100%;
    }
    .hero-metric {
      padding: 1.1rem 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      border-right: 1px solid var(--border);
    }
    .hero-metric:last-child { border-right: none; }
    .metric-val {
      font-family: var(--mono);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
    }
    .metric-lbl { font-size: 0.72rem; color: var(--muted); }

    /* ─────────────────────────────────────────
       SHARED SECTION HEADER
    ───────────────────────────────────────── */
    .sec { padding: 5.5rem 0; }
    .sec-header { margin-bottom: 3rem; }
    .sec-tag {
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--accent);
      margin-bottom: 0.9rem;
      display: block;
    }
    .sec-title {
      font-size: clamp(1.6rem, 3.2vw, 2.2rem);
      font-weight: 700;
      letter-spacing: -0.025em;
      line-height: 1.2;
      margin-bottom: 0.75rem;
      color: #F0EFEC;
    }
    .sec-sub {
      font-size: 0.95rem;
      color: var(--muted-2);
      max-width: 540px;
      line-height: 1.75;
    }

    /* ─────────────────────────────────────────
       MANIFESTE
    ───────────────────────────────────────── */
    .manifeste-wrap {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: linear-gradient(135deg, rgba(59,130,246,0.03) 0%, transparent 50%);
    }
    .manifeste-inner { max-width: 720px; }
    .manifeste-inner p {
      font-size: 1rem;
      color: var(--muted-2);
      line-height: 1.85;
      margin-bottom: 1.25rem;
    }
    .manifeste-inner .role {
      font-size: 1.05rem;
      color: var(--text);
      font-weight: 600;
    }
    .manifeste-signature {
      border-left: 2px solid var(--border-md);
      padding-left: 1.1rem;
      margin-top: 0.5rem;
    }
    .manifeste-signature p { margin-bottom: 0; }
    .manifeste-signature strong { color: var(--text); font-weight: 600; }

    /* ─────────────────────────────────────────
       FONDATEUR
    ───────────────────────────────────────── */
    .fondateur-wrap {
      border-top: 1px solid var(--border);
    }
    .fondateur-grid {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3.5rem;
      align-items: center;
      max-width: 820px;
    }
    .fondateur-photo-wrap {
      position: relative;
      width: 200px;
      height: 200px;
      flex-shrink: 0;
    }
    .fondateur-photo-wrap::before {
      content: '';
      position: absolute;
      inset: -3px;
      border-radius: 50%;
      background: conic-gradient(var(--accent), transparent 60%, var(--accent));
      animation: spin 8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .fondateur-photo-wrap::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background: var(--bg);
      margin: 3px;
    }
    .fondateur-photo {
      position: relative;
      z-index: 1;
      width: 194px;
      height: 194px;
      border-radius: 50%;
      object-fit: cover;
      margin: 3px;
    }
    .fondateur-bio .sec-tag { margin-bottom: 0.5rem; }
    .fondateur-bio h2 {
      font-size: clamp(1.4rem, 2.5vw, 1.9rem);
      font-weight: 700;
      letter-spacing: -0.025em;
      margin-bottom: 0.5rem;
      color: #F0EFEC;
    }
    .fondateur-bio p {
      font-size: 0.95rem;
      color: var(--muted-2);
      line-height: 1.75;
      margin-bottom: 0.75rem;
    }
    .fondateur-bio .sig {
      font-size: 0.9rem;
      color: var(--muted-2);
      border-left: 2px solid var(--border-md);
      padding-left: 0.9rem;
    }
    .fondateur-bio .sig strong { color: var(--text); font-weight: 600; }

    /* ─────────────────────────────────────────
       PAIN CARDS
    ───────────────────────────────────────── */
    .pain-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
    }
    .pain-card {
      background: var(--surface);
      padding: 2rem;
      transition: background 0.25s;
    }
    .pain-card:hover { background: var(--surface-2); }
    .pain-quote {
      font-style: italic;
      color: var(--muted-2);
      font-size: 0.95rem;
      margin-bottom: 1rem;
      line-height: 1.6;
    }
    .pain-answer {
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--accent);
      display: flex;
      align-items: flex-start;
      gap: 0.4rem;
    }

    /* ─────────────────────────────────────────
       PROFILS
    ───────────────────────────────────────── */
    .profils-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1rem;
    }
    .profil-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.75rem;
      position: relative;
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
    }
    .profil-card:hover {
      border-color: var(--border-md);
      transform: translateY(-4px);
      background: var(--surface-2);
    }
    .profil-num {
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--muted);
      margin-bottom: 1rem;
      display: block;
    }
    .profil-card h3 {
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: -0.015em;
      margin-bottom: 0.6rem;
      color: #F0EFEC;
    }
    .profil-pain {
      font-style: italic;
      color: var(--muted);
      font-size: 0.85rem;
      margin-bottom: 1.1rem;
      line-height: 1.6;
    }
    .profil-reco {
      font-family: var(--mono);
      font-size: 0.8rem;
      color: var(--accent);
      line-height: 1.9;
    }

    /* ─────────────────────────────────────────
       PARCOURS — BENTO STYLE
    ───────────────────────────────────────── */
    .parcours-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
      gap: 1rem;
      overflow: visible;
    }
    .pc:hover .dclick-mascot {
      transform: translateY(-6px) scale(1.04);
    }
    .pc {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2rem;
      position: relative;
      overflow: hidden;
      transition: all 0.35s cubic-bezier(0.16,1,0.3,1);
      display: flex;
      flex-direction: column;
    }
    .pc:hover {
      background: var(--surface-2);
      border-color: var(--border-md);
      transform: translateY(-5px);
    }
    .pc-num {
      font-family: var(--mono);
      font-size: 4rem;
      font-weight: 700;
      color: rgba(255,255,255,0.04);
      position: absolute;
      top: 0.75rem;
      right: 1.25rem;
      line-height: 1;
      user-select: none;
    }
    .pc-badge {
      display: inline-flex;
      align-items: center;
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      padding: 0.3rem 0.7rem;
      border-radius: 6px;
      margin-bottom: 1.1rem;
      width: fit-content;
    }
    .pc.blue  .pc-badge { background: var(--accent-dim);           color: var(--accent);  }
    .pc.green .pc-badge { background: rgba(52,211,153,0.14);       color: var(--success); }
    .pc.purple.pc-badge,
    .pc.purple .pc-badge { background: rgba(167,139,250,0.14);     color: var(--purple);  }
    .pc h3 {
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
      color: #F0EFEC;
    }
    .pc-desc { font-size: 0.9rem; color: var(--muted-2); margin-bottom: 1.25rem; line-height: 1.65; }
    .pc ul { list-style: none; padding: 0; flex: 1; }
    .pc ul li {
      font-size: 0.88rem;
      color: var(--text);
      padding: 0.3rem 0 0.3rem 1.25rem;
      position: relative;
    }
    .pc ul li::before { content: '✓'; position: absolute; left: 0; font-weight: 700; }
    .pc.blue   ul li::before { color: var(--accent);  }
    .pc.green  ul li::before { color: var(--success); }
    .pc.purple ul li::before { color: var(--purple);  }

    .pc-footer {
      margin-top: 1.5rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--border);
    }
    .pc-price {
      font-family: var(--mono);
      font-size: 1rem;
      font-weight: 700;
      line-height: 1;
      margin-bottom: 0.3rem;
    }
    .pc-free { font-size: 0.82rem; color: var(--success); font-weight: 600; margin-bottom: 0.2rem; }
    .pc.blue   .pc-price { color: var(--accent);  }
    .pc.green  .pc-price { color: var(--success); }
    .pc.purple .pc-price { color: var(--purple);  }
    .pc-format { font-size: 0.78rem; color: var(--muted); margin-bottom: 0.5rem; line-height: 1.5; }
    .pc-result {
      font-family: var(--mono);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .pc.blue   .pc-result { color: var(--accent);  }
    .pc.green  .pc-result { color: var(--success); }
    .pc.purple .pc-result { color: var(--purple);  }

    .rgpd-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.7rem;
      color: var(--success);
      background: rgba(52,211,153,0.08);
      border: 1px solid rgba(52,211,153,0.2);
      border-radius: 100px;
      padding: 0.2rem 0.65rem;
      margin-top: 0.75rem;
    }

    /* ─────────────────────────────────────────
       CAS D'USAGE
    ───────────────────────────────────────── */
    .cas-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 1rem;
    }
    .cas-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.75rem;
      transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
    }
    .cas-card:hover {
      border-color: var(--border-md);
      transform: translateY(-4px);
      background: var(--surface-2);
    }
    .cas-card h4 {
      font-family: var(--mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--accent);
      margin-bottom: 1.25rem;
    }
    .pas-block { margin-bottom: 1rem; }
    .pas-block:last-child { margin-bottom: 0; }
    .pas-label {
      font-family: var(--mono);
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      display: block;
      margin-bottom: 0.25rem;
    }
    .pas-block.solution .pas-label { color: var(--success); }
    .pas-block p { font-size: 0.88rem; color: var(--muted-2); line-height: 1.6; }
    .pas-block.solution p,
    .pas-block.action  p  { color: var(--text); }

    /* ─────────────────────────────────────────
       FAQ
    ───────────────────────────────────────── */
    .faq-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
    }
    .faq-item {
      background: var(--surface);
      padding: 1.75rem 2rem;
      transition: background 0.2s;
    }
    .faq-item:hover { background: var(--surface-2); }
    .faq-item h3 { font-size: 0.95rem; font-weight: 600; color: var(--text); margin-bottom: 0.65rem; line-height: 1.5; }
    .faq-item p  { font-size: 0.88rem; color: var(--muted-2); line-height: 1.7; }

    /* ─────────────────────────────────────────
       CTA SECTION
    ───────────────────────────────────────── */
    .cta-sec {
      border-top: 1px solid var(--border);
      padding: 6rem 0;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-sec::before {
      content: '';
      position: absolute;
