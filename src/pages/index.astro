---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />
  <Hero />

  <!-- DE LA CONFUSION À L'ACTION -->
  <section class="py-24 px-6 w-full max-w-6xl mx-auto border-t border-[#222222]/50 relative">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-white mb-4">De la confusion à <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#60A5FA] to-[#2E7BD4]">l'action</span></h2>
      <p class="text-lg text-[#A0AEC0]">Nous transformons vos freins actuels en leviers de productivité immédiats.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6">

      <!-- Card 1 -->
      <div class="relative group flex flex-col h-full hover:-translate-y-2 transition-transform duration-500">
        <div class="absolute -inset-0.5 bg-gradient-to-b from-transparent via-[#2E7BD4]/20 to-[#2E7BD4]/50 rounded-[1.5rem] blur opacity-0 group-hover:opacity-100 transition duration-700"></div>
        <div class="relative h-full flex flex-col rounded-2xl bg-[#0A0A0A] border border-[#222222] shadow-2xl overflow-hidden">
          <div class="p-8 pb-12 bg-[#141414]/40 flex flex-col items-center text-center">
            <div class="w-12 h-12 rounded-full bg-[#222222]/50 flex items-center justify-center mb-5 border border-[#333]">
              <i data-lucide="help-circle" class="w-6 h-6 text-[#666]"></i>
            </div>
            <p class="text-lg text-[#888] font-medium leading-relaxed">"Je ne sais pas par où commencer"</p>
          </div>
          <div class="relative h-0 flex justify-center z-10">
            <div class="absolute -top-6 w-12 h-12 rounded-full bg-[#0A0A0A] border border-[#222222] group-hover:border-[#2E7BD4] group-hover:bg-[#2E7BD4]/10 flex items-center justify-center shadow-[0_0_0_8px_#0A0A0A] transition-all duration-500 z-20">
              <i data-lucide="zap" class="w-5 h-5 text-[#444] group-hover:text-[#60A5FA] group-hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.8)] transition-all duration-500"></i>
            </div>
          </div>
          <div class="p-8 pt-12 bg-gradient-to-b from-[#141414] to-[#141414] group-hover:to-[#2E7BD4]/10 border-t border-dashed border-[#333] group-hover:border-solid group-hover:border-[#2E7BD4]/40 flex-1 flex flex-col items-center justify-center text-center relative transition-all duration-500">
            <div class="absolute bottom-[-20%] inset-x-0 h-32 bg-[#2E7BD4]/30 blur-[50px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
            <p class="text-xl font-semibold text-white group-hover:text-[#60A5FA] transition-colors duration-300 drop-shadow-sm relative z-10">
              Clarté immédiate sur VOTRE usage
            </p>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="relative group flex flex-col h-full hover:-translate-y-2 transition-transform duration-500">
        <div class="absolute -inset-0.5 bg-gradient-to-b from-transparent via-[#2E7BD4]/20 to-[#2E7BD4]/50 rounded-[1.5rem] blur opacity-0 group-hover:opacity-100 transition duration-700"></div>
        <div class="relative h-full flex flex-col rounded-2xl bg-[#0A0A0A] border border-[#222222] shadow-2xl overflow-hidden">
          <div class="p-8 pb-12 bg-[#141414]/40 flex flex-col items-center text-center">
            <div class="w-12 h-12 rounded-full bg-[#222222]/50 flex items-center justify-center mb-5 border border-[#333]">
              <i data-lucide="users" class="w-6 h-6 text-[#666]"></i>
            </div>
            <p class="text-lg text-[#888] font-medium leading-relaxed">"Mon équipe résiste<br />à l'IA"</p>
          </div>
          <div class="relative h-0 flex justify-center z-10">
            <div class="absolute -top-6 w-12 h-12 rounded-full bg-[#0A0A0A] border border-[#222222] group-hover:border-[#2E7BD4] group-hover:bg-[#2E7BD4]/10 flex items-center justify-center shadow-[0_0_0_8px_#0A0A0A] transition-all duration-500 z-20">
              <i data-lucide="zap" class="w-5 h-5 text-[#444] group-hover:text-[#60A5FA] group-hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.8)] transition-all duration-500"></i>
            </div>
          </div>
          <div class="p-8 pt-12 bg-gradient-to-b from-[#141414] to-[#141414] group-hover:to-[#2E7BD4]/10 border-t border-dashed border-[#333] group-hover:border-solid group-hover:border-[#2E7BD4]/40 flex-1 flex flex-col items-center justify-center text-center relative transition-all duration-500">
            <div class="absolute bottom-[-20%] inset-x-0 h-32 bg-[#2E7BD4]/30 blur-[50px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
            <p class="text-xl font-semibold text-white group-hover:text-[#60A5FA] transition-colors duration-300 drop-shadow-sm relative z-10">
              Adoption métier<br />sans friction
            </p>
          </div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="relative group flex flex-col h-full hover:-translate-y-2 transition-transform duration-500">
        <div class="absolute -inset-0.5 bg-gradient-to-b from-transparent via-[#2E7BD4]/20 to-[#2E7BD4]/50 rounded-[1.5rem] blur opacity-0 group-hover:opacity-100 transition duration-700"></div>
        <div class="relative h-full flex flex-col rounded-2xl bg-[#0A0A0A] border border-[#222222] shadow-2xl overflow-hidden">
          <div class="p-8 pb-12 bg-[#141414]/40 flex flex-col items-center text-center">
            <div class="w-12 h-12 rounded-full bg-[#222222]/50 flex items-center justify-center mb-5 border border-[#333]">
              <i data-lucide="eye-off" class="w-6 h-6 text-[#666]"></i>
            </div>
            <p class="text-lg text-[#888] font-medium leading-relaxed">"Je ne vois pas ce que ça m'apporte"</p>
          </div>
          <div class="relative h-0 flex justify-center z-10">
            <div class="absolute -top-6 w-12 h-12 rounded-full bg-[#0A0A0A] border border-[#222222] group-hover:border-[#2E7BD4] group-hover:bg-[#2E7BD4]/10 flex items-center justify-center shadow-[0_0_0_8px_#0A0A0A] transition-all duration-500 z-20">
              <i data-lucide="zap" class="w-5 h-5 text-[#444] group-hover:text-[#60A5FA] group-hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.8)] transition-all duration-500"></i>
            </div>
          </div>
          <div class="p-8 pt-12 bg-gradient-to-b from-[#141414] to-[#141414] group-hover:to-[#2E7BD4]/10 border-t border-dashed border-[#333] group-hover:border-solid group-hover:border-[#2E7BD4]/40 flex-1 flex flex-col items-center justify-center text-center relative transition-all duration-500">
            <div class="absolute bottom-[-20%] inset-x-0 h-32 bg-[#2E7BD4]/30 blur-[50px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
            <p class="text-xl font-semibold text-white group-hover:text-[#60A5FA] transition-colors duration-300 drop-shadow-sm relative z-10">
              1 cas concret<br />opérationnel validé
            </p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- 2 PROFILS -->
  <section id="offres" class="py-24 px-6 w-full max-w-5xl mx-auto border-t border-[#222222]/50">
    <div class="mb-16 text-center md:text-left">
      <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-white mb-4">3 profils, 1 seul <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#60A5FA] to-[#2E7BD4]">déclic</span></h2>
      <p class="text-lg text-[#A0AEC0]">Trouvez l'accompagnement adapté à votre structure.</p>
    </div>

    <div class="flex flex-col gap-6">

      <!-- Petite structure -->
      <div class="bg-[#141414]/60 backdrop-blur-xl border border-[#222222] hover:border-[#7B3A10]/40 hover:shadow-2xl hover:shadow-[#7B3A10]/10 transition-all duration-300 hover:-translate-y-1 p-6 md:p-8 rounded-2xl flex flex-col md:flex-row gap-6 md:gap-8 items-start md:items-center">
        <div class="flex items-center gap-4 md:w-1/3">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#7B3A10]/20 to-[#7B3A10]/5 border border-[#7B3A10]/30 flex items-center justify-center text-[#E67E22] shrink-0 shadow-[0_0_15px_rgba(123,58,16,0.2)]">
            <i data-lucide="store" class="w-6 h-6"></i>
          </div>
          <h3 class="text-xl font-medium tracking-tight text-white">Petite structure</h3>
        </div>
        <div class="md:w-1/3">
          <p class="text-base text-[#A0AEC0] italic">"Je n'ai pas le temps, je ne sais pas par où commencer"</p>
        </div>
        <div class="md:w-1/3 flex flex-col gap-3 w-full">
          <div class="bg-[#0A0A0A]/80 border border-[#222222] hover:border-[#7B3A10]/50 hover:bg-[#141414] px-5 py-4 rounded-xl text-base text-white font-medium flex items-center justify-between group transition-all cursor-pointer">
            Offre 1 — Ateliers pratiques
            <i data-lucide="arrow-right" class="w-4 h-4 text-[#444] group-hover:text-[#E67E22] group-hover:translate-x-1 transition-all"></i>
          </div>
          <div class="bg-[#0A0A0A]/80 border border-[#222222] hover:border-[#7B3A10]/50 hover:bg-[#141414] px-5 py-4 rounded-xl text-base text-white font-medium flex items-center justify-between group transition-all cursor-pointer">
            Offre 2 — Audit flash
            <i data-lucide="arrow-right" class="w-4 h-4 text-[#444] group-hover:text-[#E67E22] group-hover:translate-x-1 transition-all"></i>
          </div>
        </div>
      </div>

      <!-- PME & Services -->
      <div class="bg-[#141414]/60 backdrop-blur-xl border border-[#222222] hover:border-[#2E7BD4]/40 hover:shadow-2xl hover:shadow-[#2E7BD4]/10 transition-all duration-300 hover:-translate-y-1 p-6 md:p-8 rounded-2xl flex flex-col md:flex-row gap-6 md:gap-8 items-start md:items-center">
        <div class="flex items-center gap-4 md:w-1/3">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#2E7BD4]/20 to-[#2E7BD4]/5 border border-[#2E7BD4]/30 flex items-center justify-center text-[#60A5FA] shrink-0 shadow-[0_0_15px_rgba(46,123,212,0.2)]">
            <i data-lucide="building-2" class="w-6 h-6"></i>
          </div>
          <h3 class="text-xl font-medium tracking-tight text-white">PME &amp; Services</h3>
        </div>
        <div class="md:w-1/3">
          <p class="text-base text-[#A0AEC0] italic">"Mon équipe résiste, je ne sais pas quoi automatiser"</p>
        </div>
        <div class="md:w-1/3 flex flex-col gap-3 w-full">
          <div class="bg-[#0A0A0A]/80 border border-[#222222] hover:border-[#2E7BD4]/50 hover:bg-[#141414] px-5 py-4 rounded-xl text-base text-white font-medium flex items-center justify-between group transition-all cursor-pointer">
            Offre 2 + Offre 1 (Combo)
            <i data-lucide="arrow-right" class="w-4 h-4 text-[#444] group-hover:text-[#60A5FA] group-hover:translate-x-1 transition-all"></i>
          </div>
          <div class="bg-[#0A0A0A]/80 border border-[#222222] hover:border-[#2E7BD4]/50 hover:bg-[#141414] px-5 py-4 rounded-xl text-base text-white font-medium flex items-center justify-between group transition-all cursor-pointer">
            puis Offre 3 ou 4
            <i data-lucide="arrow-right" class="w-4 h-4 text-[#444] group-hover:text-[#60A5FA] group-hover:translate-x-1 transition-all"></i>
          </div>
        </div>
      </div>

      <!-- Industrie & Production -->
      <div class="bg-[#141414]/60 backdrop-blur-xl border border-[#222222] hover:border-[#A0AEC0]/40 hover:shadow-2xl hover:shadow-[#A0AEC0]/10 transition-all duration-300 hover:-translate-y-1 p-6 md:p-8 rounded-2xl flex flex-col md:flex-row gap-6 md:gap-8 items-start md:items-center">
        <div class="flex items-center gap-4 md:w-1/3">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#A0AEC0]/20 to-[#A0AEC0]/5 border border-[#A0AEC0]/30 flex items-center justify-center text-[#A0AEC0] shrink-0 shadow-[0_0_15px_rgba(160,174,192,0.2)]">
            <i data-lucide="factory" class="w-6 h-6"></i>
          </div>
          <h3 class="text-xl font-medium tracking-tight text-white">Industrie &amp; Production</h3>
        </div>
        <div class="md:w-1/3">
          <p class="text-base text-[#A0AEC0] italic">"Mes données terrain ne servent à rien"</p>
        </div>
        <div class="md:w-1/3 flex flex-col gap-3 w-full">
          <div class="bg-[#0A0A0A]/80 border border-[#222222] hover:border-[#A0AEC0]/50 hover:bg-[#141414] px-5 py-4 rounded-xl text-base text-white font-medium flex items-center justify-between group transition-all cursor-pointer">
            Offre 2 + Offre 4 (IoT)
            <i data-lucide="arrow-right" class="w-4 h-4 text-[#444] group-hover:text-[#A0AEC0] group-hover:translate-x-1 transition-all"></i>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- LE PARCOURS EN 4 ÉTAPES -->
  <section class="py-24 px-6 w-full max-w-6xl mx-auto border-t border-[#222222]/50">
    <div class="mb-16 max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-white mb-4">Le parcours en <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#60A5FA] to-[#2E7BD4]">4 étapes</span></h2>
    </div>

    <div class="flex flex-col max-w-4xl mx-auto w-full">

      <!-- Étape 01 -->
      <div class="bg-[#141414]/60 backdrop-blur-xl border border-[#222222] hover:border-[#2E7BD4]/30 hover:shadow-2xl hover:shadow-[#2E7BD4]/5 transition-all duration-300 p-8 md:p-10 rounded-2xl relative flex flex-col overflow-hidden group">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-[#2E7BD4]/10 rounded-full blur-3xl group-hover:bg-[#2E7BD4]/20 transition-all duration-500 z-0"></div>
        <div class="absolute top-8 right-8 text-6xl font-bold text-[#222222]/40 select-none z-10 group-hover:text-[#2E7BD4]/20 transition-colors">01</div>
        <div class="text-[#60A5FA] text-xs font-semibold tracking-widest uppercase mb-4 z-10">Maîtriser</div>
        <h3 class="text-2xl font-medium tracking-tight text-white mb-4 z-10">Ateliers IA &amp; Usage maîtrisé</h3>
        <p class="text-lg text-[#A0AEC0] mb-8 z-10 leading-relaxed">Rendre vos équipes autonomes sur les outils IA du quotidien.</p>
        <ul class="space-y-4 mb-10 z-10 flex-1">
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Prise en main : ChatGPT, Claude, Mistral, Perplexity, NotebookLM</span>
          </li>
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Bonnes pratiques de prompting et usage professionnel</span>
          </li>
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Module Shadow AI : identifier et encadrer les usages non contrôlés</span>
          </li>
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Rédaction collaborative d'une mini-charte IA interne</span>
          </li>
        </ul>
        <div class="mt-auto z-10 flex flex-col gap-5 pt-6 border-t border-[#222222]">
          <div class="flex items-center gap-3 text-sm text-[#A0AEC0]">
            <i data-lucide="clock" class="w-4 h-4 text-[#60A5FA]"></i> ½ journée ou 1 journée <span class="text-[#444]">|</span> Tous collaborateurs
          </div>
          <div class="bg-[#0A0A0A]/50 border border-[#2E7BD4]/20 px-4 py-3 rounded-lg text-sm text-[#60A5FA] font-medium text-center md:text-left shadow-inner">
            Adoption sereine · Usage cadré · Zéro résistance
          </div>
        </div>
      </div>

      <div class="flex justify-center w-full py-1">
        <div class="w-[2px] h-12 bg-gradient-to-b from-[#2E7BD4] via-[#2E7BD4]/30 to-[#222222] opacity-80 rounded-full"></div>
      </div>

      <!-- Étape 02 -->
      <div class="bg-[#141414]/60 backdrop-blur-xl border border-[#222222] hover:border-[#2E7BD4]/30 hover:shadow-2xl hover:shadow-[#2E7BD4]/5 transition-all duration-300 p-8 md:p-10 rounded-2xl relative flex flex-col overflow-hidden group">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-[#2E7BD4]/10 rounded-full blur-3xl group-hover:bg-[#2E7BD4]/20 transition-all duration-500 z-0"></div>
        <div class="absolute top-8 right-8 text-6xl font-bold text-[#222222]/40 select-none z-10 group-hover:text-[#2E7BD4]/20 transition-colors">02</div>
        <div class="text-[#60A5FA] text-xs font-semibold tracking-widest uppercase mb-4 z-10">Optimiser</div>
        <h3 class="text-2xl font-medium tracking-tight text-white mb-4 z-10">Étude d'optimisation assistée par IA</h3>
        <p class="text-lg text-[#A0AEC0] mb-8 z-10 leading-relaxed">Identifier vos gains rapides et construire votre feuille de route IA.</p>
        <ul class="space-y-4 mb-10 z-10 flex-1">
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Diagnostic flash (pré-audit) ou audit complet des processus métier</span>
          </li>
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Cartographie des tâches répétitives et automatisables</span>
          </li>
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Recommandations priorisées avec estimation des gains (temps, coûts)</span>
          </li>
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Suivi post-audit optionnel</span>
          </li>
        </ul>
        <div class="mt-auto z-10 flex flex-col gap-5 pt-6 border-t border-[#222222]">
          <div class="flex items-center gap-3 text-sm text-[#A0AEC0]">
            <i data-lucide="file-text" class="w-4 h-4 text-[#60A5FA]"></i> Rapport + Roadmap priorisée + Estimation ROI
          </div>
          <div class="bg-[#0A0A0A]/50 border border-[#2E7BD4]/20 px-4 py-3 rounded-lg text-sm text-[#60A5FA] font-medium text-center md:text-left shadow-inner">
            Actions prioritaires · Gains estimés · Démarrage immédiat
          </div>
        </div>
      </div>

      <div class="flex justify-center w-full py-1">
        <div class="w-[2px] h-12 bg-gradient-to-b from-[#2E7BD4] via-[#2E7BD4]/30 to-[#222222] opacity-80 rounded-full"></div>
      </div>

      <!-- Étape 03 -->
      <div class="bg-[#141414]/60 backdrop-blur-xl border border-[#222222] hover:border-[#2E7BD4]/30 hover:shadow-2xl hover:shadow-[#2E7BD4]/5 transition-all duration-300 p-8 md:p-10 rounded-2xl relative flex flex-col overflow-hidden group">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-[#2E7BD4]/10 rounded-full blur-3xl group-hover:bg-[#2E7BD4]/20 transition-all duration-500 z-0"></div>
        <div class="absolute top-8 right-8 text-6xl font-bold text-[#222222]/40 select-none z-10 group-hover:text-[#2E7BD4]/20 transition-colors">03</div>
        <div class="text-[#60A5FA] text-xs font-semibold tracking-widest uppercase mb-4 z-10">Créer</div>
        <h3 class="text-2xl font-medium tracking-tight text-white mb-4 z-10">Accompagnement IA Créative</h3>
        <p class="text-lg text-[#A0AEC0] mb-8 z-10 leading-relaxed">Mettre en place une chaîne de production de contenu assistée par IA.</p>
        <ul class="space-y-4 mb-10 z-10 flex-1">
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Audit des besoins créatifs et configuration des outils</span>
          </li>
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Outils : Flux, HeyGen, DALL-E, Google AI Studio, ElevenLabs</span>
          </li>
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Méthode : texte, image, vidéo, audio, avatars IA</span>
          </li>
          <li class="flex items-start gap-3 text-base text-[#A0AEC0]">
            <i data-lucide="check" class="w-5 h-5 text-[#2E7BD4] shrink-0 mt-0.5"></i>
            <span>Accompagnement à la production autonome et reproductible</span>
          </li>
        </ul>
        <div class="mt-auto z-10 flex flex-col gap-5 pt-6 border-t border-[#222222]">
          <div class="flex items-center gap-3 text-sm text-[#A0AEC0]">
            <i data-lucide="users" class="w-4 h-4 text-[#60A5FA]"></i> Atelier + accompagnement sur site
          </div>
          <div class="bg-[#0A0A0A]/50 border border-[#2E7BD4]/20 px-4 py-3 rounded-lg text-sm text-[#60A5FA] font-medium text-center md:text-left shadow-inner">
            Chaîne de production autonome opérationnelle
          </div>
        </div>
      </div>

      <div class="flex justify-center w-full py-1">
        <div class="w-[2px] h-12 bg-gradient-to-b from-[#2E7BD4] via-[#2E7BD4]/30 to-[#222222] opacity-80 rounded-full"></div>
