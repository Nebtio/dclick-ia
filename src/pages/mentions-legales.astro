---
// Mentions légales – Dclick IA
---

<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mentions légales | Dclick IA</title>
  <meta name="description" content="Mentions légales du site Dclick IA." />
  <link rel="icon" type="image/png" href="/LogoDclickV2.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      --clr-bg: #0A0A0A;
      --clr-surface: #141414;
      --clr-accent: #2E7BD4;
      --clr-accent-hover: #3B82F6;
      --clr-accent-glow: rgba(46, 123, 212, 0.25);
      --clr-text: #e8e6e3;
      --clr-text-muted: #A0AEC0;
      --clr-border: #222222;
      --font-heading: 'Sora', sans-serif;
      --font-mono: 'Space Mono', monospace;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-heading);
      background: var(--clr-bg);
      color: var(--clr-text);
      line-height: 1.6;
      overflow-x: hidden;
    }

    .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }
    .text-accent { color: var(--clr-accent); }

    /* — Nav — */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      background: rgba(12, 14, 19, 0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--clr-border);
      overflow: visible;
    }
    nav .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
      max-width: 1140px; margin: 0 auto; padding: 0.75rem 1.5rem;
    }
    nav img { height: 40px; transform: scale(4); transform-origin: left center; margin-left: 90px; margin-right: 90px; }
    nav .nav-links { display: flex; gap: 2rem; align-items: center; }
    nav .nav-links a {
      color: var(--clr-text-muted); text-decoration: none;
      font-size: 0.9rem; font-weight: 500; transition: color 0.2s;
    }
    nav .nav-links a:hover { color: var(--clr-accent); }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--clr-accent); color: var(--clr-bg);
      padding: 0.75rem 1.75rem; border-radius: 8px;
      font-weight: 600; font-size: 0.95rem;
      text-decoration: none; border: none; cursor: pointer;
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      background: var(--clr-accent-hover);
      transform: translateY(-2px);
      box-shadow: 0 8px 25px var(--clr-accent-glow);
    }
    .btn-sm { padding: 0.5rem 1.25rem; font-size: 0.85rem; }

    .nav-toggle { display: none; background: none; border: none; color: var(--clr-text); font-size: 1.5rem; cursor: pointer; }
    @media (max-width: 768px) {
      .nav-toggle { display: block; }
      nav .nav-links {
        display: none; position: absolute; top: 100%; left: 0; right: 0;
        background: var(--clr-surface); flex-direction: column; padding: 1.5rem;
        border-bottom: 1px solid var(--clr-border);
      }
      nav .nav-links.open { display: flex; }
    }

    /* — Legal content — */
    .legal-content {
      max-width: 760px; margin: 0 auto;
      padding-top: 8rem; padding-bottom: 4rem;
    }
    .legal-content h1 {
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      font-weight: 700; margin-bottom: 2.5rem;
    }
    .legal-content h2 {
      font-size: 1.2rem; font-weight: 600; color: var(--clr-accent);
      margin-top: 2rem; margin-bottom: 0.75rem;
    }
    .legal-content p {
      color: var(--clr-text-muted); font-size: 0.95rem;
      line-height: 1.8; margin-bottom: 0.5rem;
    }

    /* — Footer — */
    footer { border-top: 1px solid var(--clr-border); padding: 2.5rem 0; }
    .footer-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .footer-brand { display: flex; align-items: center; gap: 0.75rem; }
    .footer-brand img { height: 32px; }
    .footer-brand span { font-size: 0.85rem; color: var(--clr-text-muted); }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a { color: var(--clr-text-muted); text-decoration: none; font-size: 0.8rem; transition: color 0.2s; }
    .footer-links a:hover { color: var(--clr-accent); }
    .footer-copy { width: 100%; text-align: center; font-size: 0.8rem; color: var(--clr-text-muted); margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--clr-border); }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="/" style="color: var(--clr-text); text-decoration: none; font-size: 1.1rem; font-weight: 700;">Dclick <span style="color: var(--clr-accent);">IA</span></a>
      <button class="nav-toggle" aria-label="Menu" onclick="document.querySelector('.nav-links').classList.toggle('open')">&#9776;</button>
      <div class="nav-links">
        <a href="/#offres">Offres</a>
        <a href="/#cas-usage">Cas d'usage</a>
        <a href="/#contact">Contact</a>
        <a href="/#besoin" class="btn-primary btn-sm">Diagnostic gratuit &rarr;</a>
      </div>
    </div>
  </nav>

  <!-- CONTENU -->
  <div class="container">
    <div class="legal-content">
      <h1>Mentions <span class="text-accent">légales</span></h1>

      <h2>Éditeur du site</h2>
      <p>Dclick IA</p>
      <p>Entrepreneur individuel</p>
      <p>SIRET : 929 409 530</p>
      <p>Email : contact@dclickia.fr</p>

      <h2>Directeur de la publication</h2>
      <p>Benoit, en qualité de gérant de Dclick IA.</p>

      <h2>Hébergeur</h2>
      <p>OVHcloud</p>
      <p>2 rue Kellermann, 59100 Roubaix, France</p>
      <p>Téléphone : 1007</p>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <img src="/LogoDclickV2.png" alt="Dclick IA" />
          <span>Automatisation simple. Résultats concrets.</span>
        </div>
        <div class="footer-links">
          <a href="/mentions-legales">Mentions légales</a>
          <a href="/politique-de-confidentialite">Politique de confidentialité</a>
        </div>
      </div>
      <p class="footer-copy">
        Données hébergées en France &#x1F1EB;&#x1F1F7; &nbsp;&middot;&nbsp; &copy; 2026 Dclick IA — Giennois, Centre-Val de Loire
      </p>
    </div>
  </footer>

</body>
</html>
