---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Diagnostic IA gratuit (30 min) | Dclick IA, Gien"
  description="Un échange de 30 min pour identifier si l'IA peut vous faire gagner du temps. Gratuit, sans engagement. Consultant basé à Gien."
>

  <!-- ——— PAGE HERO ——— -->
  <div class="page-hero">
    <div class="container">
      <span class="page-tag">Étape 02 — Optimiser</span>
      <h1>Diagnostic flash gratuit — 30 min pour y voir clair</h1>
      <p class="page-lead">
        Un échange simple de 30 minutes pour comprendre si l'IA peut vous aider dans votre quotidien.
      </p>
    </div>
  </div>

  <!-- ——— OFFRE DIAGNOSTIC ——— -->
  <section>
    <div class="container">
      <div class="parcours-grid" style="max-width: 700px;">

        <div class="parcours-card step-optimiser">
          <span class="step-number">02</span>
          <span class="step-badge">Optimiser</span>
          <h3>Diagnostic de rentabilité</h3>
          <p class="step-desc">Identifier vos gains rapides et construire votre feuille de route IA.</p>
          <ul>
            <li>Diagnostic flash gratuit (30 min, sans engagement)</li>
            <li>Audit complet des processus métier</li>
            <li>Cartographie des tâches répétitives et automatisables</li>
            <li>Recommandations priorisées + estimation ROI</li>
          </ul>
          <p class="step-free">Flash : gratuit</p>
          <p class="step-price">Audit complet : 1 000€ HT</p>
          <p class="step-result">Actions prioritaires · Gains estimés · Démarrage rapide</p>
          <span class="rgpd-badge">✓ Conforme RGPD</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ——— CONCRÈTEMENT ——— -->
  <section style="border-top: 1px solid var(--clr-border);">
    <div class="container">
      <h2 class="section-title">Concrètement, on fait <span class="text-accent">quoi ?</span></h2>
      <div class="pain-grid">
        <div class="pain-card">
          <p class="pain-answer">→ On passe en revue vos tâches du quotidien.</p>
        </div>
        <div class="pain-card">
          <p class="pain-answer">→ On repère celles où l'IA change vraiment la donne.</p>
        </div>
        <div class="pain-card">
          <p class="pain-answer">→ Et on vous dit franchement si ça vaut le coup.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— PRISE DE RDV ——— -->
  <section id="rdv" style="border-top: 1px solid var(--clr-border);">
    <div class="container" style="max-width: 760px;">
      <h2 class="section-title">Prendre <span class="text-accent">rendez-vous</span></h2>
      <p class="intro-text">Choisissez un créneau — c'est gratuit et sans engagement.</p>
      <iframe
        data-tally-src="https://tally.so/embed/J907RX?alignLeft=1&hideTitle=1&transparentBackground=1"
        loading="lazy"
        width="100%"
        height="500"
        frameborder="0"
        title="Prise de rendez-vous diagnostic flash"
      ></iframe>
    </div>
  </section>

</SiteLayout>
